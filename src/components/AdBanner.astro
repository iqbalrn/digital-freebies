---
// Adsterra Ad Banner Component
// Replace placeholder with your actual Adsterra code

interface Props {
  type?: 'banner' | 'rectangle' | 'skyscraper';
  class?: string;
}

const { type = 'banner', class: className = '' } = Astro.props;

const adSizes = {
  banner: '728x90',
  rectangle: '300x250',
  skyscraper: '160x600',
};
---

<div class={`ad-container ${className}`} data-ad-type={type}>
  <!-- Adsterra Banner Placeholder -->
  <div class="bg-gray-100 border border-gray-200 rounded-lg flex items-center justify-center overflow-hidden" style={`min-height: ${type === 'banner' ? '90px' : type === 'rectangle' ? '250px' : '600px'}; min-width: ${type === 'skyscraper' ? '160px' : '100%'}; max-width: ${type === 'skyscraper' ? '160px' : '728px'}`}>
    <div class="text-center p-4">
      <div class="w-12 h-12 bg-gray-200 rounded-lg mx-auto mb-2 flex items-center justify-center">
        <svg class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
      </div>
      <p class="text-sm text-gray-500">Advertisement</p>
      <p class="text-xs text-gray-400 mt-1">{adSizes[type]}</p>
    </div>
  </div>

  <!--
  Replace the placeholder above with your actual Adsterra code:
  1. Create account at https://adsterra.com
  2. Create ad zones
  3. Copy the script code here
  -->
</div>

<style>
  .ad-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>
