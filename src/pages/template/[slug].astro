---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TemplateCard from '../../components/TemplateCard.astro';
import AdBanner from '../../components/AdBanner.astro';
import { Download, Star, Eye, Heart, Share2, FileSpreadsheet, FileVideo, FileImage, FileText, Presentation } from 'lucide-astro';
import templatesData from '../../data/templates.json';

const base = '/digital-freebies';

export function getStaticPaths() {
  return templatesData.templates.map((template) => ({
    params: { slug: template.slug },
    props: { template },
  }));
}

const { template } = Astro.props;

const relatedTemplates = templatesData.templates
  .filter(t => t.category === template.category && t.id !== template.id)
  .slice(0, 4);

const formatIcons: Record<string, any> = {
  xlsx: FileSpreadsheet,
  xls: FileSpreadsheet,
  png: FileImage,
  jpg: FileImage,
  jpeg: FileImage,
  psd: FileImage,
  mp4: FileVideo,
  mov: FileVideo,
  avi: FileVideo,
  pptx: Presentation,
  ppt: Presentation,
  docx: FileText,
  doc: FileText,
  pdf: FileText,
};

const FormatIcon = formatIcons[template.format] || FileText;
---

<MainLayout title={`${template.title} - TemplateHub`} description={template.description}>
  <Header />

  <main class="min-h-screen bg-gray-50">
    <!-- Breadcrumb -->
    <div class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <nav class="flex items-center gap-2 text-sm">
          <a href={`${base}/`} class="text-gray-500 hover:text-violet-600">
            Home
          </a>
          <span class="text-gray-400">/</span>
          <a href={`${base}/category/${template.category}`} class="text-gray-500 hover:text-violet-600 capitalize">
            {template.category}
          </a>
          <span class="text-gray-400">/</span>
          <span class="text-violet-600 font-medium truncate max-w-[200px]">
            {template.title}
          </span>
        </nav>
      </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left: Preview & Details -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Preview Card -->
          <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
            <!-- Preview Image -->
            <div class="aspect-video bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
              <div class="text-center">
                <FormatIcon class="w-24 h-24 text-gray-300 mx-auto mb-4" />
                <p class="text-gray-400">Preview not available</p>
                <p class="text-sm text-gray-500 mt-1">Upload screenshot to enable preview</p>
              </div>
            </div>
          </div>

          <!-- Description -->
          <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
            <h2 class="text-xl font-bold text-gray-900 mb-4">Description</h2>
            <p class="text-gray-600 leading-relaxed">
              {template.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mt-6">
              {template.tags.map((tag: string) => (
                <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- Right: Download Card -->
        <div class="space-y-6">
          <!-- Download Card -->
          <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm sticky top-24">
            <h1 class="text-2xl font-bold text-gray-900 mb-2">
              {template.title}
            </h1>

            <!-- Category Badge -->
            <span class="inline-block px-3 py-1 bg-violet-100 text-violet-700 rounded-full text-sm font-medium mb-4 capitalize">
              {template.category}
            </span>

            <!-- Rating -->
            <div class="flex items-center gap-3 mb-6">
              <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <Star
                    class={`w-5 h-5 ${i < Math.floor(template.rating) ? 'text-amber-400 fill-amber-400' : 'text-gray-300'}`}
                  />
                ))}
              </div>
              <span class="text-gray-600">
                {template.rating} ({template.reviews} reviews)
              </span>
            </div>

            <!-- File Info -->
            <div class="grid grid-cols-2 gap-4 mb-6 p-4 bg-gray-50 rounded-xl">
              <div>
                <p class="text-xs text-gray-500 mb-1">Format</p>
                <p class="font-semibold text-gray-900 flex items-center gap-2">
                  <FormatIcon class="w-4 h-4" />
                  .{template.format}
                </p>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-1">Size</p>
                <p class="font-semibold text-gray-900">{template.fileSize}</p>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-1">Downloads</p>
                <p class="font-semibold text-gray-900">{template.downloads.toLocaleString()}</p>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-1">Added</p>
                <p class="font-semibold text-gray-900">{new Date(template.createdAt).toLocaleDateString()}</p>
              </div>
            </div>

            <!-- Download Button -->
            <a
              href={`${base}/download/${template.slug}`}
              class="flex items-center justify-center gap-3 w-full py-4 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-700 hover:to-indigo-700 text-white font-bold text-lg rounded-xl shadow-lg shadow-violet-500/30 hover:shadow-violet-500/50 transition-all duration-200"
            >
              <Download class="w-5 h-5" />
              Download Free
            </a>

            <!-- Warning -->
            <p class="text-xs text-gray-500 text-center mt-4">
              By downloading, you agree to our Terms of Service
            </p>

            <!-- Actions -->
            <div class="flex items-center justify-center gap-3 mt-6 pt-6 border-t border-gray-100">
              <button class="p-3 text-gray-400 hover:text-violet-600 bg-gray-50 rounded-xl transition-colors">
                <Heart class="w-5 h-5" />
              </button>
              <button class="p-3 text-gray-400 hover:text-violet-600 bg-gray-50 rounded-xl transition-colors">
                <Share2 class="w-5 h-5" />
              </button>
            </div>
          </div>

          <!-- Ad Banner -->
          <AdBanner type="rectangle" className="mx-auto" />
        </div>
      </div>

      <!-- Related Templates -->
      {relatedTemplates.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Related Templates
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {relatedTemplates.map((t) => (
              <TemplateCard
                id={t.id}
                title={t.title}
                slug={t.slug}
                category={t.category}
                thumbnail={t.thumbnail}
                format={t.format}
                rating={t.rating}
                reviews={t.reviews}
                downloads={t.downloads}
                featured={t.featured}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer />
</MainLayout>
