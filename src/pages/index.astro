---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TemplateCard from '../components/TemplateCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import AdBanner from '../components/AdBanner.astro';
import { Search, Shield, Download, Star, ArrowRight, Sparkles } from 'lucide-astro';
import templatesData from '../data/templates.json';

const base = '/digital-freebies';

const featuredTemplates = templatesData.templates.filter(t => t.featured);
const latestTemplates = [...templatesData.templates]
  .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
  .slice(0, 8);
const categories = templatesData.categories;
---

<MainLayout title="TemplateHub - Free Premium Templates Download">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-violet-50 via-white to-indigo-50">
      <!-- Animated Background -->
      <div class="absolute inset-0">
        <div class="absolute top-20 left-10 w-72 h-72 bg-violet-400/20 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute bottom-20 right-10 w-96 h-96 bg-indigo-400/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
        <div class="text-center max-w-4xl mx-auto">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-violet-100 text-violet-700 rounded-full text-sm font-medium mb-6 animate-fade-in">
            <Sparkles class="w-4 h-4" />
            <span>100% Free • No Registration Required</span>
          </div>

          <!-- Headline -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 mb-6 animate-slide-up">
            Free Premium Templates
            <span class="block bg-gradient-to-r from-violet-600 via-indigo-600 to-violet-600 bg-clip-text text-transparent bg-[length:200%_auto]">
              For Your Projects
            </span>
          </h1>

          <!-- Subheadline -->
          <p class="text-lg md:text-xl text-gray-600 mb-10 max-w-2xl mx-auto animate-slide-up" style="animation-delay: 100ms">
            Download high quality Excel, Canva, Video, PowerPoint & Word templates. Professional designs, instantly available.
          </p>

          <!-- Search Bar -->
          <div class="relative max-w-2xl mx-auto animate-slide-up" style="animation-delay: 200ms">
            <div class="relative flex items-center">
              <Search class="absolute left-5 w-6 h-6 text-gray-400" />
              <input
                type="text"
                placeholder="Search templates (e.g., 'Excel Keuangan', 'Canva Instagram')..."
                class="w-full pl-14 pr-32 py-4 bg-white border-2 border-gray-200 rounded-2xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-violet-500 shadow-xl shadow-violet-500/10 transition-all duration-200"
              />
              <button class="absolute right-2 px-6 py-2.5 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-700 hover:to-indigo-700 text-white font-semibold rounded-xl transition-all duration-200 flex items-center gap-2 shadow-lg shadow-violet-500/25">
                <Search class="w-4 h-4" />
                Search
              </button>
            </div>
          </div>

          <!-- Quick Stats -->
          <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-12 animate-fade-in" style="animation-delay: 400ms">
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent">500+</div>
              <div class="text-sm text-gray-500">Templates</div>
            </div>
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent">50K+</div>
              <div class="text-sm text-gray-500">Downloads</div>
            </div>
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent">5★</div>
              <div class="text-sm text-gray-500">Avg Rating</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Templates -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 flex items-center gap-2">
              <span>🔥</span> Featured Templates
            </h2>
            <p class="text-gray-600 mt-1">
              Hand-picked premium templates for you
            </p>
          </div>
          <a href={`${base}/templates`} class="hidden sm:flex items-center gap-2 text-violet-600 font-medium hover:gap-3 transition-all duration-200">
            View All
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {featuredTemplates.map((template) => (
            <TemplateCard
              id={template.id}
              title={template.title}
              slug={template.slug}
              category={template.category}
              thumbnail={template.thumbnail}
              format={template.format}
              rating={template.rating}
              reviews={template.reviews}
              downloads={template.downloads}
              featured={template.featured}
            />
          ))}
        </div>

        <div class="mt-8 text-center sm:hidden">
          <a href={`${base}/templates`} class="inline-flex items-center gap-2 px-6 py-3 bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl transition-colors duration-200">
            View All Templates
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
            📂 Browse by Category
          </h2>
          <p class="text-gray-600 mt-2">
            Find the perfect template for your needs
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
          {categories.map((category) => (
            <CategoryCard
              id={category.id}
              name={category.name}
              icon={category.icon}
              description={category.description}
              count={category.count}
              href={`${base}/category/${category.id}`}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Latest Templates -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 flex items-center gap-2">
              <span>✨</span> Latest Additions
            </h2>
            <p class="text-gray-600 mt-1">
              Fresh templates added recently
            </p>
          </div>
          <a href={`${base}/templates`} class="hidden sm:flex items-center gap-2 text-violet-600 font-medium hover:gap-3 transition-all duration-200">
            View All
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {latestTemplates.map((template) => (
            <TemplateCard
              id={template.id}
              title={template.title}
              slug={template.slug}
              category={template.category}
              thumbnail={template.thumbnail}
              format={template.format}
              rating={template.rating}
              reviews={template.reviews}
              downloads={template.downloads}
              featured={template.featured}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-16 bg-gradient-to-br from-violet-600 via-indigo-600 to-violet-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-3xl font-bold text-white">
            Why Choose TemplateHub?
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center p-6 rounded-2xl bg-white/10 backdrop-blur-sm">
            <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <Download class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Instant Download</h3>
            <p class="text-violet-100">
              No waiting, no registration. Click and download immediately.
            </p>
          </div>

          <div class="text-center p-6 rounded-2xl bg-white/10 backdrop-blur-sm">
            <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <Star class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Premium Quality</h3>
            <p class="text-violet-100">
              Hand-crafted templates with professional design.
            </p>
          </div>

          <div class="text-center p-6 rounded-2xl bg-white/10 backdrop-blur-sm">
            <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <Shield class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Safe & Secure</h3>
            <p class="text-violet-100">
              All files are scanned. No malware, no hidden costs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          📬 Get New Templates First
        </h2>
        <p class="text-gray-600 mb-8">
          Subscribe and get notified when we add new templates. No spam, unsubscribe anytime.
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            placeholder="Enter your email"
            class="flex-1 px-5 py-3 bg-white border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-violet-500"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-700 hover:to-indigo-700 text-white font-semibold rounded-xl transition-all duration-200 whitespace-nowrap shadow-lg shadow-violet-500/25"
          >
            Subscribe
          </button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>
