---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Heart, Globe, Zap, Shield, Mail } from 'lucide-astro';
---

<MainLayout title="About Us - TemplateHub">
  <Header />

  <main class="min-h-screen bg-gray-50">
    <!-- Hero -->
    <section class="bg-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          About <span class="text-violet-600">TemplateHub</span>
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed">
          We're on a mission to make professional design accessible to everyone. Free templates, no registration required, instant downloads.
        </p>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-12 bg-gradient-to-br from-violet-600 to-indigo-600">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center text-white">
          <div>
            <div class="text-4xl md:text-5xl font-bold mb-2">500+</div>
            <div class="text-violet-100">Templates</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-bold mb-2">50K+</div>
            <div class="text-violet-100">Downloads</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-bold mb-2">100+</div>
            <div class="text-violet-100">Countries</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-bold mb-2">4.9★</div>
            <div class="text-violet-100">Avg Rating</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Mission</h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              We believe that great design shouldn't be expensive. That's why we curate and create high-quality templates that anyone can download and use for free.
            </p>
            <p class="text-gray-600 leading-relaxed">
              Whether you're a small business owner, a student, or a creative professional, our templates help you look professional without the designer price tag.
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">What We Offer</h2>
            <ul class="space-y-3">
              {[
                'Free Excel templates for business & finance',
                'Canva templates for social media & branding',
                'Video templates for YouTube & presentations',
                'PowerPoint templates for professional pitches',
                'Word templates for documents & contracts',
              ].map((item) => (
                <li class="flex items-start gap-3 text-gray-600">
                  <span class="w-2 h-2 bg-violet-500 rounded-full mt-2 shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Our Values</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-14 h-14 bg-violet-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <Zap class="w-7 h-7 text-violet-600" />
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Fast & Easy</h3>
            <p class="text-sm text-gray-600">No registration, no waiting. Download instantly with one click.</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-violet-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <Shield class="w-7 h-7 text-violet-600" />
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Safe & Secure</h3>
            <p class="text-sm text-gray-600">All files are scanned. No malware, no hidden costs.</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-violet-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <Globe class="w-7 h-7 text-violet-600" />
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Global Access</h3>
            <p class="text-sm text-gray-600">Available worldwide in multiple languages.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Get In Touch</h2>
        <p class="text-gray-600 mb-8">
          Have questions, suggestions, or want to contribute templates? We'd love to hear from you!
        </p>
        <a
          href="mailto:contact@templatehub.com"
          class="inline-flex items-center gap-2 px-6 py-3 bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl transition-colors"
        >
          <Mail class="w-5 h-5" />
          Contact Us
        </a>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>
