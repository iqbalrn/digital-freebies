---
import { Download, Eye, Star, FileSpreadsheet, FileVideo, FileImage, Presentation, FileText } from 'lucide-astro';

interface Props {
  id: string;
  title: string;
  slug: string;
  category: string;
  thumbnail: string;
  format: string;
  rating: number;
  reviews: number;
  downloads: number;
  featured?: boolean;
}

const { id, title, slug, category, thumbnail, format, rating, reviews, downloads, featured = false } = Astro.props;

const formatIcons: Record<string, any> = {
  xlsx: FileSpreadsheet,
  xls: FileSpreadsheet,
  png: FileImage,
  jpg: FileImage,
  jpeg: FileImage,
  psd: FileImage,
  mp4: FileVideo,
  mov: FileVideo,
  avi: FileVideo,
  pptx: Presentation,
  ppt: Presentation,
  docx: FileText,
  doc: FileText,
  pdf: FileText,
};

const formatColors: Record<string, string> = {
  xlsx: 'text-green-600 bg-green-100',
  xls: 'text-green-600 bg-green-100',
  png: 'text-pink-600 bg-pink-100',
  jpg: 'text-pink-600 bg-pink-100',
  psd: 'text-blue-600 bg-blue-100',
  mp4: 'text-purple-600 bg-purple-100',
  mov: 'text-purple-600 bg-purple-100',
  pptx: 'text-orange-600 bg-orange-100',
  ppt: 'text-orange-600 bg-orange-100',
  docx: 'text-blue-600 bg-blue-100',
  pdf: 'text-red-600 bg-red-100',
};

const FormatIcon = formatIcons[format] || FileText;
const formatColorClass = formatColors[format] || 'text-gray-600 bg-gray-100';

const fullStars = Math.floor(rating);
const hasHalfStar = rating % 1 >= 0.5;
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-violet-200">
  <!-- Thumbnail -->
  <a href={`/template/${slug}`} class="block relative overflow-hidden">
    <div class="aspect-[4/3] bg-gradient-to-br from-gray-100 to-gray-200">
      <!-- Placeholder dengan pattern -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-center">
          <FormatIcon class="w-16 h-16 text-gray-300 mx-auto mb-2" />
          <span class="text-xs text-gray-400 uppercase tracking-wider">{category}</span>
        </div>
      </div>
      <!-- Hover overlay -->
      <div class="absolute inset-0 bg-violet-600/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-3">
        <span class="flex items-center gap-1.5 px-4 py-2 bg-white text-violet-600 rounded-full text-sm font-semibold shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
          <Eye class="w-4 h-4" />
          Preview
        </span>
      </div>
    </div>
    {featured && (
      <span class="absolute top-3 left-3 px-2.5 py-1 bg-gradient-to-r from-amber-500 to-orange-500 text-white text-xs font-bold rounded-full shadow-lg">
        ⭐ Featured
      </span>
    )}
  </a>

  <!-- Content -->
  <div class="p-4">
    <!-- Category & Format -->
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-violet-600 uppercase tracking-wider capitalize">
        {category}
      </span>
      <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-medium ${formatColorClass}`}>
        <FormatIcon class="w-3.5 h-3.5" />
        {format.toUpperCase()}
      </span>
    </div>

    <!-- Title -->
    <a href={`/template/${slug}`}>
      <h3 class="font-semibold text-gray-900 mb-2 line-clamp-2 group-hover:text-violet-600 transition-colors">
        {title}
      </h3>
    </a>

    <!-- Rating -->
    <div class="flex items-center gap-2 mb-3">
      <div class="flex items-center gap-0.5">
        {Array.from({ length: 5 }).map((_, i) => (
          <Star
            class={`w-4 h-4 ${i < fullStars ? 'text-amber-400 fill-amber-400' : i === fullStars && hasHalfStar ? 'text-amber-400 fill-amber-400/50' : 'text-gray-300'}`}
          />
        ))}
      </div>
      <span class="text-sm text-gray-500">
        {rating} ({reviews})
      </span>
    </div>

    <!-- Download Button -->
    <a
      href={`/template/${slug}`}
      class="flex items-center justify-center gap-2 w-full py-2.5 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-700 hover:to-indigo-700 text-white font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40"
    >
      <Download class="w-4 h-4" />
      Download Free
    </a>

    <!-- Stats -->
    <div class="flex items-center justify-center gap-4 mt-3 text-xs text-gray-500">
      <span>👁️ {downloads.toLocaleString()} downloads</span>
    </div>
  </div>
</article>
