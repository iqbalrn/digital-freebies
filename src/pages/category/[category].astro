---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TemplateCard from '../../components/TemplateCard.astro';
import AdBanner from '../../components/AdBanner.astro';
import { Filter, Grid, List } from 'lucide-astro';
import templatesData from '../../data/templates.json';

const base = '/digital-freebies';

export function getStaticPaths() {
  return templatesData.categories.map((category) => ({
    params: { category: category.id },
    props: { categoryName: category.name },
  }));
}

const { category } = Astro.params;
const { categoryName } = Astro.props;

const filteredTemplates = templatesData.templates.filter(t => t.category === category);
---

<MainLayout title={`${categoryName} Templates - TemplateHub`}>
  <Header />

  <main class="min-h-screen bg-gray-50">
    <!-- Breadcrumb -->
    <div class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <nav class="flex items-center gap-2 text-sm">
          <a href={`${base}/`} class="text-gray-500 hover:text-violet-600">
            Home
          </a>
          <span class="text-gray-400">/</span>
          <a href={`${base}/categories`} class="text-gray-500 hover:text-violet-600">
            Categories
          </a>
          <span class="text-gray-400">/</span>
          <span class="text-violet-600 font-medium capitalize">
            {categoryName}
          </span>
        </nav>
      </div>
    </div>

    <!-- Header -->
    <div class="bg-white py-8 md:py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2 capitalize">
          {categoryName} Templates
        </h1>
        <p class="text-gray-600">
          {filteredTemplates.length} templates available
        </p>
      </div>
    </div>

    <!-- Filter & Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar Filters -->
        <aside class="lg:w-64 shrink-0">
          <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm sticky top-24">
            <h3 class="font-semibold text-gray-900 mb-4 flex items-center gap-2">
              <Filter class="w-4 h-4" />
              Filters
            </h3>

            <!-- Reset Button -->
            <button class="w-full py-2 text-sm text-violet-600 hover:bg-violet-50 rounded-lg transition-colors">
              Reset Filters
            </button>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1">
          <!-- Sort Bar -->
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
            <p class="text-gray-600">
              Showing <span class="font-semibold text-gray-900">{filteredTemplates.length}</span> templates
            </p>
            <div class="flex items-center gap-3">
              <select class="px-4 py-2 bg-white border border-gray-200 rounded-xl text-gray-700 text-sm focus:outline-none focus:border-violet-500">
                <option value="newest">Newest First</option>
                <option value="popular">Most Popular</option>
                <option value="rating">Highest Rated</option>
                <option value="name">Name (A-Z)</option>
              </select>
              <div class="hidden sm:flex items-center gap-1 bg-white border border-gray-200 rounded-xl p-1">
                <button class="p-2 text-violet-600 bg-violet-100 rounded-lg">
                  <Grid class="w-4 h-4" />
                </button>
                <button class="p-2 text-gray-400 hover:text-gray-600 rounded-lg transition-colors">
                  <List class="w-4 h-4" />
                </button>
              </div>
            </div>
          </div>

          <!-- Templates Grid -->
          {filteredTemplates.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {filteredTemplates.map((template) => (
                <TemplateCard
                  id={template.id}
                  title={template.title}
                  slug={template.slug}
                  category={template.category}
                  thumbnail={template.thumbnail}
                  format={template.format}
                  rating={template.rating}
                  reviews={template.reviews}
                  downloads={template.downloads}
                  featured={template.featured}
                />
              ))}
            </div>
          ) : (
            <div class="text-center py-16">
              <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-10 h-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">No templates found</h3>
              <p class="text-gray-500 mb-6">Try adjusting your filters or browse other categories.</p>
              <a href={`${base}/categories`} class="inline-flex items-center gap-2 px-6 py-3 bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl transition-colors">
                Browse Categories
              </a>
            </div>
          )}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</MainLayout>
