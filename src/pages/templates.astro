---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TemplateCard from '../components/TemplateCard.astro';
import AdBanner from '../components/AdBanner.astro';
import { Search } from 'lucide-astro';
import templatesData from '../data/templates.json';

const templates = templatesData.templates;
const categories = templatesData.categories;
---

<MainLayout title="All Templates - TemplateHub">
  <Header />

  <main class="min-h-screen bg-gray-50">
    <!-- Header -->
    <section class="bg-white py-12 md:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          🗂️ All Templates
        </h1>
        <p class="text-gray-600">
          Browse our complete collection of free templates
        </p>
      </div>
    </section>

    <!-- Search Bar -->
    <section class="py-6 bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative max-w-2xl">
          <Search class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" />
          <input
            type="text"
            id="search-input"
            placeholder="Search templates..."
            class="w-full pl-12 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-violet-500 transition-colors"
          />
        </div>
      </div>
    </section>

    <!-- Templates Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {templates.map((template) => (
          <TemplateCard
            id={template.id}
            title={template.title}
            slug={template.slug}
            category={template.category}
            thumbnail={template.thumbnail}
            format={template.format}
            rating={template.rating}
            reviews={template.reviews}
            downloads={template.downloads}
            featured={template.featured}
          />
        ))}
      </div>
    </div>
  </main>

  <Footer />
</MainLayout>
