---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="Terms of Service - TemplateHub">
  <Header />

  <main class="min-h-screen bg-gray-50 dark:bg-dark-300 py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Terms of Service</h1>

      <div class="bg-white dark:bg-dark-100 rounded-2xl p-8 border border-gray-100 dark:border-gray-800">
        <p class="text-gray-600 dark:text-gray-400">Last updated: June 2026</p>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">1. Acceptance of Terms</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          By accessing and using TemplateHub, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website.
        </p>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">2. Service Description</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          TemplateHub provides free templates for personal and commercial use. All templates are provided "as is" without any warranties.
        </p>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">3. Usage Rights</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          You may use our templates for:
        </p>
        <ul class="list-disc list-inside text-gray-600 dark:text-gray-400 space-y-2 mb-6">
          <li>Personal projects</li>
          <li>Commercial projects (clients, businesses)</li>
          <li>Educational purposes</li>
          <li>Modification and customization</li>
        </ul>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">4. Prohibited Uses</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          You may NOT:
        </p>
        <ul class="list-disc list-inside text-gray-600 dark:text-gray-400 space-y-2 mb-6">
          <li>Resell or redistribute our templates as-is</li>
          <li>Claim ownership of our templates</li>
          <li>Use templates for illegal purposes</li>
          <li>Remove attribution or watermarks (if any)</li>
        </ul>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">5. Third-Party Links</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          Our website may contain links to third-party websites (e.g., Google Drive). We are not responsible for the content or practices of these external sites.
        </p>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">6. Advertisements</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          Our website displays advertisements from Adsterra and other third-party ad networks. We are not responsible for the content of these advertisements.
        </p>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">7. Disclaimer</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          TemplateHub is provided "as is" without warranties of any kind. We do not guarantee that the website will be error-free or uninterrupted.
        </p>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">8. Limitation of Liability</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          We shall not be liable for any damages arising from the use of our website or templates.
        </p>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">9. Changes to Terms</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          We reserve the right to modify these terms at any time. Continued use of the website constitutes acceptance of the modified terms.
        </p>

        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-4">10. Contact</h2>
        <p class="text-gray-600 dark:text-gray-400">
          For questions about these terms, contact us at <a href="mailto:legal@templatehub.com" class="text-primary-600 hover:underline">legal@templatehub.com</a>.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</MainLayout>
