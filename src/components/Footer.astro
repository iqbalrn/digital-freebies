---
import { Github, Twitter, Mail, Heart } from 'lucide-astro';

const base = '/digital-freebies';

const footerLinks = {
  resources: [
    { name: 'All Templates', href: `${base}/templates` },
    { name: 'Categories', href: `${base}/categories` },
  ],
  company: [
    { name: 'About Us', href: `${base}/about` },
    { name: 'Privacy Policy', href: `${base}/privacy` },
    { name: 'Terms of Service', href: `${base}/terms` },
  ],
  support: [
    { name: 'Contact', href: `mailto:contact@templatehub.com` },
  ]
};
---

<footer class="bg-white border-t border-gray-200">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href={`${base}/`} class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-gradient-to-br from-violet-500 to-indigo-600 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 8V16M4 8L8 4L16 8L20 4M4 8L8 12L16 8M20 4V16M20 4L16 8M16 8V16"/>
            </svg>
          </div>
          <span class="text-xl font-bold text-gray-900">TemplateHub</span>
        </a>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">
          Free premium templates for everyone. Download high quality Excel, Canva, Video, and PowerPoint templates for your projects.
        </p>
        <div class="flex items-center gap-3">
          <a href="#" class="p-2 text-gray-400 hover:text-violet-600 bg-gray-100 rounded-lg transition-colors">
            <Twitter class="w-5 h-5" />
          </a>
          <a href="https://github.com/iqbalrn" class="p-2 text-gray-400 hover:text-violet-600 bg-gray-100 rounded-lg transition-colors">
            <Github class="w-5 h-5" />
          </a>
          <a href="mailto:contact@templatehub.com" class="p-2 text-gray-400 hover:text-violet-600 bg-gray-100 rounded-lg transition-colors">
            <Mail class="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Resources</h3>
        <ul class="space-y-3">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-gray-600 hover:text-violet-600 transition-colors text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-gray-600 hover:text-violet-600 transition-colors text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Support</h3>
        <ul class="space-y-3">
          {footerLinks.support.map((link) => (
            <li>
              <a href={link.href} class="text-gray-600 hover:text-violet-600 transition-colors text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-500">
          © 2026 TemplateHub. Made with <Heart class="w-4 h-4 inline text-red-500 fill-red-500" /> for creators worldwide.
        </p>
      </div>
    </div>
  </div>
</footer>
